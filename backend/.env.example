# ─────────────────────────────────────────────────────────────────────────────
# Earniq AI — Environment Variables
#
# SETUP:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your values below
#   3. Never commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (zero-config, works out of the box — recommended for local dev):
DATABASE_URL=sqlite:///./earniq.db

# MySQL (production):
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/earniq

# PostgreSQL (alternative):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/earniq

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to any long random string in production
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── Redis (optional — app works without it, just no caching) ─────────────────
REDIS_URL=redis://localhost:6379/0

# ── Razorpay (test mode) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_ACCOUNT_NUMBER=your_razorpay_account_number_here

# ── External APIs ─────────────────────────────────────────────────────────────
# OpenWeatherMap — get your free key at https://openweathermap.org/api
OWM_API_KEY=your_openweathermap_api_key_here

# AQICN — get your free token at https://aqicn.org/data-platform/token/
AQICN_TOKEN=your_aqicn_token_here

# ── CORS (frontend URL) ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" on live server — enables HTTPS redirect + strict CORS
ENV=development

# ── Optional: Sentry (leave blank to disable) ────────────────────────────────
SENTRY_DSN=
