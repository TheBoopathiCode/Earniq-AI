# ─────────────────────────────────────────────────────────────────────────────
# Earniq AI — Frontend Environment Variables
#
# SETUP:
#   Copy this file:  cp .env.example .env
#   The defaults below work out of the box for local development.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API URL — proxied through Vite dev server (no CORS issues)
VITE_API_URL=/api

# OpenWeatherMap free key — used for live DCS signals in registration wizard
VITE_OWM_KEY=your_openweathermap_api_key_here

# AQICN free token — used for live AQI readings
VITE_AQICN_KEY=your_aqicn_token_here
